# Lokal mock için gerekirse açılır. Resmî sunucuda bunları yazmayın;
# EVALUATION_SERVER_URL + TEAM_NAME/PASSWORD otomatik resmî modu seçer.
# HURGOR_BASE_URL=http://127.0.0.1:8765
# HURGOR_FRAME_ENDPOINT=/api/frames/next
# HURGOR_PREDICTION_ENDPOINT=/api/predictions
# HURGOR_PROGRESS_ENDPOINT=/api/status
# HURGOR_API_CONTRACT=local
HURGOR_USER_URL=/users/1/
HURGOR_SESSION_URL=/session/1/

# Resmi Takım Bağlantı Arayüzü değişkenleri.
# Gerçek değerleri sadece .env dosyasına yazın; .env Git'e eklenmez.
TEAM_NAME=
PASSWORD=
EVALUATION_SERVER_URL=http://havaciliktayapayzeka.teknofest.org:1025/
SESSION_NAME=ONLINE_YARISMA_2026
HURGOR_AUTH_SCHEME=auto
HURGOR_AUTH_TOKEN=
# HURGOR_TOKEN_ENDPOINT=/auth/

# Zaman aşımı ve tekrar deneme ayarları.
HURGOR_HTTP_TIMEOUT_SECONDS=2.0
HURGOR_MAX_RETRIES=3
HURGOR_RETRY_BASE_SECONDS=0.10
HURGOR_ERROR_COOLDOWN_SECONDS=0.25
HURGOR_INFERENCE_TIMEOUT_SECONDS=0.90
HURGOR_INFERENCE_STARTUP_TIMEOUT_SECONDS=15.0
# Art arda timeoutlarda model-process yeniden başlatma fırtınasını keser. Devre
# açıkken şeması geçerli fallback POST edilir; süre bitince model tekrar denenir.
HURGOR_INFERENCE_CIRCUIT_BREAKER_THRESHOLD=2
HURGOR_INFERENCE_CIRCUIT_BREAKER_COOLDOWN_FRAMES=30
HURGOR_SLA_SECONDS=1.0
HURGOR_TARGET_FPS=1.5
HURGOR_LOG_EVERY=25
HURGOR_QUEUE_MAXSIZE=3
HURGOR_THREAD_JOIN_TIMEOUT_SECONDS=10
HURGOR_LOG_FILE=system.log
HURGOR_METRICS_FILE=logs/metrics.jsonl
HURGOR_DIAGNOSTICS_DIR=diagnostics

# Graceful degradation: 5 yavaş karede ağır modülleri kapat, 10 hızlı karede aç.
HURGOR_DEGRADE_THRESHOLD_MS=800
HURGOR_DEGRADE_AFTER_FRAMES=5
HURGOR_RECOVER_THRESHOLD_MS=250
HURGOR_RECOVER_AFTER_FRAMES=10

# Model ve kamera ayarları. Runtime .pt/.h5 kabul etmez; ONNX/engine kullanın.
HURGOR_YOLO_ONNX_PATH=
HURGOR_MODEL_MANIFEST_PATH=
HURGOR_MODEL_SHA256=
# Sınıfa özel eşikler model SHA-256 değerine bağlı JSON profilden okunur.
HURGOR_DETECTOR_THRESHOLDS_PATH=
HURGOR_DETECTOR_CONFIDENCE=0.25
HURGOR_DETECTOR_IOU_THRESHOLD=0.45
HURGOR_DETECTOR_CROSS_CLASS_IOU_THRESHOLD=0.90
# İsteğe bağlı iki sınıflı termal uzman. Termal karelerde yalnızca `insan`
# çıktısı bu modelden alınır; araç/UAP/UAİ ana modelden gelmeye devam eder.
HURGOR_THERMAL_SPECIALIST_ONNX_PATH=
HURGOR_THERMAL_SPECIALIST_MANIFEST_PATH=
HURGOR_THERMAL_SPECIALIST_SHA256=
HURGOR_THERMAL_SPECIALIST_CONFIDENCE=0.10
HURGOR_THERMAL_SPECIALIST_TIMEOUT_MS=200
HURGOR_THERMAL_SPECIALIST_SLOW_THRESHOLD_MS=180
HURGOR_THERMAL_SPECIALIST_COOLDOWN_FRAMES=30
HURGOR_THERMAL_SPECIALIST_COOLDOWN_SECONDS=20
# Boş bırakılırsa macOS'ta CPU izolasyonu; NVIDIA'da ana TensorRT/CUDA sağlayıcısı
# otomatik seçilir. Yalnızca hedef benchmark'ı gerektirirse elle değiştirin.
HURGOR_THERMAL_SPECIALIST_ONNX_PROVIDERS=
HURGOR_THERMAL_SPECIALIST_ONNX_INTRA_OP_THREADS=1
# Sadece açık mock/dry-run için true yapın. Resmi koşuda varsayılan false kalmalı.
HURGOR_ALLOW_NOOP_DETECTOR=false
HURGOR_INFERENCE_PROCESS_ENABLED=true
HURGOR_ENABLE_EXPERIMENTAL_VO=true
HURGOR_MULTIPROCESSING_START_METHOD=spawn
# Boş bırakılırsa mevcut donanıma göre TensorRT -> CUDA -> CoreML -> CPU seçilir.
# Hedef yarışma cihazında gerçek oturum benchmark'ı ile yeniden doğrulanmalıdır.
HURGOR_ONNX_PROVIDERS=
HURGOR_ONNX_INTRA_OP_THREADS=2
HURGOR_ONNX_INTER_OP_THREADS=1
HURGOR_OPENCV_NUM_THREADS=1
HURGOR_REFERENCE_IMAGES_DIR=
HURGOR_REFERENCE_CACHE_DIR=artifacts/references
# veri/Kalibrasyon_Parametreleri.txt içindeki doğrulanmış 1920x1080 RGB kalibrasyonu.
HURGOR_CAMERA_FX=1413.3
HURGOR_CAMERA_FY=1418.8
HURGOR_CAMERA_ALTITUDE_M=10
# GPS sağlıklı karelerden öğrenen homografi/RANSAC + SE(3) odometri ayarları.
# Zaman sıralı doğrulama, görüntü hareketinin son-konumu-tut tabanını geçebildiğini
# kanıtlamadan kesinti sırasında hareket üretmez.
HURGOR_VO_MIN_CALIBRATION_SAMPLES=20
HURGOR_VO_MAX_CALIBRATION_SAMPLES=450
HURGOR_VO_VALIDATION_FRACTION=0.20
HURGOR_VO_MIN_VALIDATION_SAMPLES=20
HURGOR_VO_MAX_STEP_SKILL_RATIO=0.85
HURGOR_VO_MAX_TRAJECTORY_SKILL_RATIO=0.75
HURGOR_VO_MAX_BIAS_RATIO=0.50
HURGOR_VO_MIN_INLIERS=24
HURGOR_VO_MIN_INLIER_RATIO=0.45
HURGOR_VO_RANSAC_THRESHOLD_PX=2.5
HURGOR_VO_MAX_REPROJECTION_ERROR_PX=3.0
HURGOR_VO_MAX_STEP_M=20.0
HURGOR_VO_FALLBACK_DECAY=0.85
HURGOR_VO_PROJECTIVE_FEATURES=true

# Mock sunucu ayarları.
HURGOR_MOCK_FRAME_COUNT=2250
HURGOR_MOCK_HEALTHY_FRAMES=450
HURGOR_MOCK_CORRUPT_EVERY=0
HURGOR_MOCK_EMPTY_EVERY=0
HURGOR_MOCK_GET_DELAY_MS=0
HURGOR_MOCK_POST_DELAY_MS=0
HURGOR_MOCK_IMAGE_DIR=
HURGOR_MOCK_VIDEO_PATH=
HURGOR_MOCK_TRANSLATION_CSV_PATH=
HURGOR_MOCK_FRAME_STRIDE=1
HURGOR_MOCK_VIDEO_NAME=hurgor_mock_v1
HURGOR_MOCK_MODALITY=rgb
HURGOR_MOCK_USERNAME=hurgor_test
HURGOR_MOCK_PASSWORD=test_password
HURGOR_MOCK_TOKEN_EXPIRE_AFTER_REQUESTS=0
HURGOR_MOCK_RATE_LIMIT_EVERY=0
HURGOR_MOCK_SERVER_ERROR_EVERY=0
HURGOR_MOCK_RETRY_AFTER_SECONDS=0.01
